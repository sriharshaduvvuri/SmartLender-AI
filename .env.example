# SmartLender AI Environment Configuration Template
# Rename this file to '.env' and populate the values for production deployment.

# Secret key used by Flask for session signing (provide a long, random sequence in production)
SECRET_KEY=replace_with_a_long_random_secret

# Administrator credential seeding (highly recommended to override default 'admin' / 'admin123')
ADMIN_USERNAME=replace_with_admin_username
ADMIN_PASSWORD=replace_with_a_strong_admin_password
